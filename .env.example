# OpenAI Config (Để trống để dùng Mock LLM fallback khi chạy offline)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# Database Config (Dùng PostgreSQL theo Docker Compose, hoặc SQLite cục bộ)
# Dùng PostgreSQL: postgresql://postgres:password@localhost:5432/sales_copilot
# Dùng SQLite: sqlite:///./sales_assistant.db
DATABASE_URL=postgresql://postgres:password@localhost:5432/sales_copilot

# Qdrant Config
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=truck_products
EMBEDDING_DIMENSION=1536

# Neo4j Config
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# Retriever Configs
VECTOR_TOP_K=5
GRAPH_TOP_K=5
TOP_K_HYBRID_RETRIEVER=3
